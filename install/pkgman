#!/bin/sh
# ==============================================================================
# pkgman - Universal Package Manager Wrapper
# ==============================================================================
# Provides a consistent interface for package management across different
# Linux distributions (Debian/Ubuntu, RHEL/Fedora, Arch), macOS (Homebrew/Native),
# FreeBSD (pkg), and OpenBSD (pkg_add/pkg_delete/pkg_info).
# ==============================================================================

set -eu

# ------------------------------------------------------------------------------
# HELP
# ------------------------------------------------------------------------------
show_help() {
    cat <<'EOF'
PKGMAN - Universal Package Manager
==============================================================================

DESCRIPTION:
    A universal package manager wrapper that provides consistent commands
    across different operating systems. Automatically detects the underlying
    package manager and translates commands appropriately.

SUPPORTED SYSTEMS:
    - Debian, Ubuntu, Linux Mint, Pop!_OS, Kali (apt)
    - Fedora, CentOS, RHEL (dnf)
    - Arch Linux, Manjaro (pacman)
    - macOS (Native softwareupdate + Homebrew, plus App Store via mas if installed)
    - FreeBSD (pkg)
    - OpenBSD (pkg_add / pkg_delete / pkg_info, plus syspatch for base system)

USAGE:
    pkgman <option> [package(s)]
    pkgman ?

OPTIONS:
    -u          Update system packages and clean up old packages
                Also updates Flatpak and Snap packages if installed (Linux),
                applies native macOS updates and Homebrew (macOS), updates
                Mac App Store apps if 'mas' is installed (macOS), and applies
                base system patches via syspatch (OpenBSD)
    
    -i          Install specified package(s)
    
    -r          Remove specified package(s) and their configuration files
    
    -s          Search for packages matching keyword(s)
    
    -q          Quiet mode - suppress all output (combine with other options)
    
    -h, ?       Display this help message

EXAMPLES:
    Update the entire system:
        pkgman -u
    
    Quietly update the system (for scripts/cron):
        pkgman -q -u
    
    Install a package:
        pkgman -i nginx
    
    Install multiple packages:
        pkgman -i nginx php mysql-server
    
    Remove a package:
        pkgman -r apache2
    
    Search for packages:
        pkgman -s "web server"

DISTRIBUTION MAPPING:
    Command     apt (Debian)           dnf (RHEL)          pacman (Arch)
    -------     ------------           ----------          -------------
    -u          apt update &&          dnf upgrade -y      pacman -Syu
                apt dist-upgrade -y
    
    -i          apt install -y         dnf install -y      pacman -S --noconfirm
    
    -r          apt remove             dnf remove -y       pacman -Rs --noconfirm
                --purge -y
    
    -s          apt search             dnf search          pacman -Ss

    Command     macOS (Native/Brew)    pkg (FreeBSD)       pkg_add (OpenBSD)
    -------     ------------           -------------       -----------------
    -u          softwareupdate -ia &&  pkg update &&       pkg_add -u &&
                brew upgrade           pkg upgrade -y      syspatch
    
    -i          brew install           pkg install -y      pkg_add
    
    -r          brew uninstall         pkg delete -y       pkg_delete
    
    -s          brew search            pkg search          pkg_info -Q

NOTES:
    - Requires root privileges for install, remove, and update operations
      (macOS native softwareupdate requires sudo; Homebrew intentionally runs 
      without sudo and will be used internally where required)
    - The -q (quiet) flag must come before other flags
    - Wildcards are supported in package names (e.g., "nginx*")
    - Cleanup (autoremove/cleanup) is automatically performed after updates
    - On OpenBSD, 'syspatch' is run as part of -u to patch the base system
    - Multiple packages are processed individually to prevent one failure
      from blocking others

SEE ALSO:
    apt, dnf, pacman, brew, softwareupdate, pkg, pkg_add, syspatch, snap, flatpak, mas

EOF
}

# ------------------------------------------------------------------------------
# DETECT DISTRIBUTION
# ------------------------------------------------------------------------------
detect_distro() {
    local kernel
    kernel=$(uname -s 2>/dev/null || echo "unknown")

    case "${kernel}" in
        Darwin)
            echo "macos"
            return
            ;;
        FreeBSD)
            echo "freebsd"
            return
            ;;
        OpenBSD)
            echo "openbsd"
            return
            ;;
    esac

    if [ -f /etc/os-release ]; then
        # shellcheck source=/dev/null
        . /etc/os-release
        echo "${ID}"
    else
        echo "unknown"
    fi
}

# ------------------------------------------------------------------------------
# MAIN
# ------------------------------------------------------------------------------
main() {
    # Handle help as first argument
    if [ "${1:-}" = "?" ] || [ "${1:-}" = "help" ] || \
       [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ] || \
       [ -z "${1:-}" ];
    then
        show_help
        exit 0
    fi

    # Detect distribution
    local distro
    distro=$(detect_distro)

    # Parse flags
    local quiet=false
    local action=""

    while [ $# -gt 0 ];
    do
        case "$1" in
            q|-q)
                quiet=true
                shift
                ;;
            u|-u)
                action="update"
                shift
                ;;
            i|-i|a|-a)
                action="install"
                shift
                break
                ;;
            r|-r|d|-d)
                action="remove"
                shift
                break
                ;;
            s|-s)
                action="search"
                shift
                break
                ;;
            h|-h|--help|\?)
                show_help
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done

    # Validate we have an action
    if [ -z "${action}" ];
    then
        show_help
        exit 0
    fi

    # Execute based on distribution
    local output="/dev/stdout"
    [ "${quiet}" = true ] && output="/dev/null"

    case "${distro}" in
        ubuntu|debian|kali|pop|mint|linuxmint)
            case "${action}" in
                update)
                    sudo apt-get update > "${output}" 2>&1
                    sudo apt-get dist-upgrade -y > "${output}" 2>&1
                    sudo apt-get autoremove -y > "${output}" 2>&1
                    sudo apt-get autoclean > "${output}" 2>&1
                    ;;
                install)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! sudo apt-get install -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! sudo apt-get remove --purge -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    apt search "$@"
                    ;;
            esac
            ;;

        fedora|centos|rhel|rocky|alma)
            case "${action}" in
                update)
                    sudo dnf upgrade -y > "${output}" 2>&1
                    sudo dnf autoremove -y > "${output}" 2>&1
                    ;;
                install)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! sudo dnf install -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! sudo dnf remove -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    dnf search "$@"
                    ;;
            esac
            ;;

        arch|manjaro)
            case "${action}" in
                update)
                    sudo pacman -Syu --noconfirm > "${output}" 2>&1
                    sudo pacman -Sc --noconfirm > "${output}" 2>&1
                    ;;
                install)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! sudo pacman -S --noconfirm "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! sudo pacman -Rs --noconfirm "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    pacman -Ss "$@"
                    ;;
            esac
            ;;

        macos)
            case "${action}" in
                update)
                    [ "${quiet}" != true ] && echo "--- Updating macOS Native System ---"
                    sudo softwareupdate -ia > "${output}" 2>&1 || true

                    if command -v brew >/dev/null 2>&1; then
                        [ "${quiet}" != true ] && echo "--- Updating Homebrew Packages ---"
                        brew update > "${output}" 2>&1
                        brew upgrade > "${output}" 2>&1
                        brew cleanup > "${output}" 2>&1
                    fi
                    ;;
                install)
                    if ! command -v brew >/dev/null 2>&1; then
                        echo "Error: Homebrew ('brew') not found. Install it from https://brew.sh to use package installation features on macOS." >&2
                        exit 1
                    fi
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! brew install "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if ! command -v brew >/dev/null 2>&1; then
                        echo "Error: Homebrew ('brew') not found. Install it from https://brew.sh to use package removal features on macOS." >&2
                        exit 1
                    fi
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! brew uninstall "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if ! command -v brew >/dev/null 2>&1; then
                        echo "Error: Homebrew ('brew') not found. Install it from https://brew.sh to use search features on macOS." >&2
                        exit 1
                    fi
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    brew search "$@"
                    ;;
            esac
            ;;

        freebsd)
            case "${action}" in
                update)
                    sudo pkg update > "${output}" 2>&1
                    sudo pkg upgrade -y > "${output}" 2>&1
                    sudo pkg autoremove -y > "${output}" 2>&1
                    sudo pkg clean -y > "${output}" 2>&1
                    ;;
                install)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! sudo pkg install -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! sudo pkg delete -y "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    pkg search "$@"
                    ;;
            esac
            ;;

        openbsd)
            case "${action}" in
                update)
                    sudo pkg_add -u > "${output}" 2>&1
                    sudo syspatch > "${output}" 2>&1 || true
                    ;;
                install)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Installing: ${pkg}"
                        if ! sudo pkg_add "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to install ${pkg}" >&2
                        fi
                    done
                    ;;
                remove)
                    if [ -z "$*" ]; then
                        echo "Error: No package specified" >&2
                        exit 1
                    fi
                    for pkg in "$@"; do
                        [ "${quiet}" != true ] && echo "Removing: ${pkg}"
                        if ! sudo pkg_delete "${pkg}" > "${output}" 2>&1; then
                            [ "${quiet}" != true ] && echo "Warning: Failed to remove ${pkg}" >&2
                        fi
                    done
                    ;;
                search)
                    if [ -z "$*" ]; then
                        echo "Error: No search keyword specified" >&2
                        exit 1
                    fi
                    pkg_info -Q "$@"
                    ;;
            esac
            ;;

        *)
            echo "Error: Unsupported distribution: ${distro}" >&2
            exit 1
            ;;
    esac

    # Update supplementary package sources if available (only for system update)
    if [ "${action}" = "update" ]; then
        if command -v flatpak >/dev/null 2>&1; then
            [ "${quiet}" != true ] && echo "--- Updating Flatpaks ---"
            flatpak update -y > "${output}" 2>&1 || true
        fi
        if command -v snap >/dev/null 2>&1; then
            [ "${quiet}" != true ] && echo "--- Updating Snaps ---"
            sudo snap refresh > "${output}" 2>&1 || true
        fi
        if [ "${distro}" = "macos" ] && command -v mas >/dev/null 2>&1; then
            [ "${quiet}" != true ] && echo "--- Updating Mac App Store apps ---"
            mas upgrade > "${output}" 2>&1 || true
        fi
    fi

    [ "${quiet}" != true ] && echo ""
}

main "$@"
