#!/bin/sh

HOSTS_FILE="/etc/hosts"
PING_4=1
PING_6=1

# Parse command line options using POSIX-compliant loop
while [ $# -gt 0 ]; do
    case "$1" in
        -4)
            PING_4=1
            PING_6=0
            shift
            ;;
        -6)
            PING_4=0
            PING_6=1
            shift
            ;;
        *)
            printf "Usage: %s [-4] [-6]\n" "$0" >&2
            exit 1
            ;;
    esac
done

if [ ! -f "$HOSTS_FILE" ]; then
    printf "Error: %s not found.\n" "$HOSTS_FILE" >&2
    exit 1
fi

OS=$(uname -s)

# Safe printf formatting to prevent interpretation of dashes as options
printf '%s\n' "---------------------------------------------------------------"
printf "%-40s %-15s %s\n" "IP Address" "Hostname" "Status"
printf '%s\n' "---------------------------------------------------------------"

sed -n '/# BEGIN gravinet/,/# END gravinet/p' "$HOSTS_FILE" | grep -v '^#' | \
while read -r ip host extra; do
    
    if [ -z "$ip" ] || [ -z "$host" ]; then
        continue
    fi

    # Detect address family
    case "$ip" in
        *:*) is_ipv6=1 ;;
        *)   is_ipv6=0 ;;
    esac

    # Skip addresses based on user flags
    if [ "$is_ipv6" -eq 1 ] && [ "$PING_6" -eq 0 ]; then
        continue
    fi
    if [ "$is_ipv6" -eq 0 ] && [ "$PING_4" -eq 0 ]; then
        continue
    fi

    # Execute platform-specific ping execution
    if [ "$OS" = "Linux" ]; then
        if [ "$is_ipv6" -eq 1 ]; then
            ping -6 -c 1 -W 2 "$ip" >/dev/null 2>&1
        else
            ping -c 1 -W 2 "$ip" >/dev/null 2>&1
        fi
    elif [ "$OS" = "Darwin" ]; then
        if [ "$is_ipv6" -eq 1 ]; then
            # macOS ping6 does not support a timeout flag; handles dead hosts via -c 1 natively
            ping6 -c 1 "$ip" >/dev/null 2>&1
        else
            ping -c 1 -t 2 "$ip" >/dev/null 2>&1
        fi
    elif [ "$OS" = "FreeBSD" ]; then
        # FreeBSD ping uses -W <milliseconds>
        if [ "$is_ipv6" -eq 1 ]; then
            ping6 -c 1 -W 2000 "$ip" >/dev/null 2>&1
        else
            ping -c 1 -W 2000 "$ip" >/dev/null 2>&1
        fi
    elif [ "$OS" = "OpenBSD" ]; then
        # OpenBSD ping lacks a standard timeout flag; use the native timeout utility
        if [ "$is_ipv6" -eq 1 ]; then
            timeout 2 ping6 -c 1 "$ip" >/dev/null 2>&1
        else
            timeout 2 ping -c 1 "$ip" >/dev/null 2>&1
        fi
    else
        # Generic fallback
        if [ "$is_ipv6" -eq 1 ] && command -v ping6 >/dev/null 2>&1; then
            ping6 -c 1 "$ip" >/dev/null 2>&1
        else
            ping -c 1 "$ip" >/dev/null 2>&1
        fi
    fi

    if [ $? -eq 0 ]; then
        status="ALIVE"
    else
        status="DEAD"
    fi

    printf "%-40s %-15s %s\n" "$ip" "$host" "$status"
done

printf "%s\n"
