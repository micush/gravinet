#!/bin/bash

USER=root
HOSTS=(
    "mcfed"
    "gn-cush1"
    "gn-cush2"
    "gn-freebsd"
    "gn-openbsd"
    "gn-macos"
    "gn-win11"
    "gn-ionos1"
    "gn-ionos2"
    "gn-ionos3"
    "gn-manjaro"
    "gn-rocky"
    "gn-win10"
    "gn-debian"
)

# 1. Local Git & Prep
cd ~/projects/gravinet
chmod 777 install/*.sh
git add .
git commit -m "bug fixes"

# Push to git in the background so it doesn't block the rsync/ssh deployments
git push & 
GIT_PUSH_PID=$! # Save the PID to wait for it at the very end

cd ..

# 2. Define the single host deployment function
deploy_to_host() {
    local HOST=$1
    local USER="root" # Hardcoded inside function for GNU parallel environment

    # Sync files
    rsync -avh -e "ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1" --delete --exclude .git ~/projects/gravinet/ --exclude distribute-gravinet $USER@$HOST:gravinet/ > /dev/null 2>&1

    # Detect OS
    REMOTE_OS=$(ssh -n -o ServerAliveInterval=3 -o ServerAliveCountMax=1 "$USER@$HOST" "uname" 2>/dev/null)
    REMOTE_OS=$(echo "$REMOTE_OS" | tr -d '\r')

    # Run installation based on OS
    case "$REMOTE_OS" in
        "Linux")
            ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1 $USER@$HOST gravinet/install/install-linux.sh
            ;;
        "FreeBSD")
            ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1 $USER@$HOST gravinet/install/install-freebsd.sh
            ;;
        "OpenBSD")
            ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1 $USER@$HOST gravinet/install/install-openbsd.sh
            ;;
        "Darwin")
            ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1 $USER@$HOST gravinet/install/install-macos.sh
            ;;
        "Windows_NT")
            ssh -o ServerAliveInterval=3 -o ServerAliveCountMax=1 $USER@$HOST gravinet\\install\\install-windows.bat
            ;;
        *)
            echo "Warning: Unknown OS ($REMOTE_OS) on $HOST"
            ;;
    esac
}

# Export the function so GNU Parallel can see and execute it
export -f deploy_to_host

# 3. Run parallel jobs
echo "Starting parallel deployment..."
parallel --jobs 0 --tag deploy_to_host ::: "${HOSTS[@]}"

# 4. Ensure the background git push finishes successfully before exiting completely
echo "Waiting for background Git push to complete..."
wait $GIT_PUSH_PID

echo "All deployments and Git push completed successfully!"

echo ""

